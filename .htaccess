# ════════════════════════════════════════════════════════════════
# .htaccess — Game Developer Portfolio
# IONOS Apache-Konfiguration für Unity WebGL Gzip-Dateien
# KRITISCH: Ohne diese Datei laden Unity-Spiele nicht!
# ════════════════════════════════════════════════════════════════

# ── Unity WebGL Gzip MIME Types ─────────────────────────────────
AddEncoding gzip .gz

<FilesMatch "\.data\.gz$">
    ForceType application/octet-stream
    Header set Content-Encoding gzip
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

<FilesMatch "\.wasm\.gz$">
    ForceType application/wasm
    Header set Content-Encoding gzip
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

<FilesMatch "\.framework\.js\.gz$">
    ForceType application/javascript
    Header set Content-Encoding gzip
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>

<FilesMatch "\.loader\.js$">
    Header set Cache-Control "no-cache, no-store"
</FilesMatch>

# ── Allgemeine Komprimierung (HTML, CSS, JS) ────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Caching ──────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg  "access plus 1 month"
    ExpiresByType image/png   "access plus 1 month"
    ExpiresByType image/webp  "access plus 1 month"
    ExpiresByType text/css    "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ── CORS für WebGL ───────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>

# ── Sicherheit ───────────────────────────────────────────────────
Options -Indexes
